# EditorConfig configuration for C-Man Dev Workspace
# This file ensures consistent coding styles across different editors and IDEs

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# PowerShell files
[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.psm1]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.psd1]
indent_style = space
indent_size = 4
end_of_line = crlf

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# JavaScript and TypeScript files
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
max_line_length = 88

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# XML files
[*.xml]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# CSS files
[*.css]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# Batch files
[*.{bat,cmd}]
indent_style = space
indent_size = 2
end_of_line = crlf

# Configuration files
[*.{ini,cfg,conf}]
indent_style = space
indent_size = 2

# Docker files
[Dockerfile*]
indent_style = space
indent_size = 2

[*.dockerfile]
indent_style = space
indent_size = 2

# Terraform files
[*.tf]
indent_style = space
indent_size = 2

[*.tfvars]
indent_style = space
indent_size = 2

# Ansible files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Go files
[*.go]
indent_style = tab
indent_size = 4

# Rust files
[*.rs]
indent_style = space
indent_size = 4

# Java files
[*.java]
indent_style = space
indent_size = 4

# C/C++ files
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

# C# files
[*.cs]
indent_style = space
indent_size = 4

# Ruby files
[*.rb]
indent_style = space
indent_size = 2

# PHP files
[*.php]
indent_style = space
indent_size = 4

# SQL files
[*.sql]
indent_style = space
indent_size = 2

# R files
[*.r]
indent_style = space
indent_size = 2

# MATLAB files
[*.m]
indent_style = space
indent_size = 4

# Lua files
[*.lua]
indent_style = space
indent_size = 2

# Perl files
[*.pl]
indent_style = space
indent_size = 4

# Scala files
[*.scala]
indent_style = space
indent_size = 2

# Kotlin files
[*.kt]
indent_style = space
indent_size = 4

# Swift files
[*.swift]
indent_style = space
indent_size = 4

# Dart files
[*.dart]
indent_style = space
indent_size = 2

# Vue files
[*.vue]
indent_style = space
indent_size = 2

# Svelte files
[*.svelte]
indent_style = space
indent_size = 2

# Angular files
[*.component.ts]
indent_style = space
indent_size = 2

# React files
[*.{jsx,tsx}]
indent_style = space
indent_size = 2

# Styled Components
[*.styled.{js,ts}]
indent_style = space
indent_size = 2

# GraphQL files
[*.{graphql,gql}]
indent_style = space
indent_size = 2

# Prisma files
[schema.prisma]
indent_style = space
indent_size = 2

# TOML files
[*.toml]
indent_style = space
indent_size = 2

# INI files
[*.ini]
indent_style = space
indent_size = 2

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# Log files
[*.log]
trim_trailing_whitespace = false
insert_final_newline = false

# Lock files
[{package-lock.json,yarn.lock,pnpm-lock.yaml,poetry.lock,Pipfile.lock}]
trim_trailing_whitespace = false
insert_final_newline = false

# Binary files
[*.{png,jpg,jpeg,gif,ico,svg,woff,woff2,ttf,eot}]
trim_trailing_whitespace = false
insert_final_newline = false

# Archive files
[*.{zip,tar,gz,rar,7z}]
trim_trailing_whitespace = false
insert_final_newline = false

# Executable files
[*.{exe,msi,deb,rpm,dmg,pkg}]
trim_trailing_whitespace = false
insert_final_newline = false
