# EditorConfig - https://editorconfig.org
# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# PowerShell
[*.{ps1,psm1,psd1,ps1xml}]
indent_size = 4
charset = utf-8-bom

# Python
[*.py]
indent_size = 4
max_line_length = 120

# JavaScript / TypeScript
[*.{js,ts,jsx,tsx}]
indent_size = 2

# Web files
[*.{html,css,scss,less}]
indent_size = 2

# Data files
[*.{json,jsonc}]
indent_size = 2

# YAML
[*.{yaml,yml}]
indent_size = 2

# XML
[*.xml]
indent_size = 2

# Markdown
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Batch / CMD
[*.{bat,cmd}]
indent_size = 4

# Shell scripts (LF line endings)
[*.{sh,bash}]
end_of_line = lf
indent_size = 2

# Makefiles (require tabs)
[Makefile]
indent_style = tab

# Git config files
[.git*]
indent_size = 4
