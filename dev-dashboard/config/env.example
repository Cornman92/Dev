# Server Configuration
PORT=3000
NODE_ENV=development
WEBSOCKET_PORT=3001

# Workspace integration (optional): root path for workspace_report.json and Invoke-McpHealthCheck.ps1
# Default: parent of dev-dashboard directory (e.g. D:\Dev when dashboard is at D:\Dev\dev-dashboard)
# WORKSPACE_ROOT=D:\Dev

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_ORG=your_organization_name
GITHUB_API_BASE=https://api.github.com

# Database Configuration
DATABASE_PATH=./database/dashboard.db

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Update Intervals (in milliseconds)
COMMIT_SYNC_INTERVAL=300000
BUILD_SYNC_INTERVAL=60000
METRICS_UPDATE_INTERVAL=60000

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_RECONNECT_DELAY=5000


