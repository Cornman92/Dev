# =============================================================================
# C-Man Dev Workspace - Cursor AI .cursorignore
# Extended exclusions for Cursor AI context optimization
# =============================================================================

# Include all .gitignore patterns
# (Cursor automatically respects .gitignore, but we'll be explicit here)

# =============================================================================
# LARGE VENDOR DIRECTORIES & EXTERNAL TOOLKITS
# =============================================================================

# Large PowerShell toolkits (thousands of files)
GaymerPC/
OwnershipToolkit/
tools/
extracted_functions/
PowerShell/

# Node.js dependencies
node_modules/

# Python dependencies
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.env/
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# BUILD ARTIFACTS & COMPILED FILES
# =============================================================================

# Build outputs
dist/
build/
out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Webpack bundles
webpack-stats.json
.webpack/

# TypeScript compiled files
*.js.map
*.d.ts.map

# =============================================================================
# DOCUMENTATION & GENERATED CONTENT
# =============================================================================

# Generated documentation
docs/_build/
docs/build/
site/
_site/

# API documentation
api-docs/
swagger-ui/
openapi.json

# Generated markdown
*.generated.md
*.auto.md

# =============================================================================
# TEST COVERAGE & REPORTS
# =============================================================================

# Coverage reports
coverage/
htmlcov/
.coverage
.coverage.*
*.lcov
.nyc_output/

# Test results
test-results/
test-reports/
junit.xml
test.xml

# Performance test results
*.perf.log
performance-results/
benchmark-results/

# =============================================================================
# LOGS & TEMPORARY FILES
# =============================================================================

# Log files
*.log
logs/
log/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo

# Cache directories
.cache/
cache/
.parcel-cache/
.eslintcache
.stylelintcache

# =============================================================================
# IDE & EDITOR SPECIFIC
# =============================================================================

# VS Code
.vscode/
.history/

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Cursor
.cursor/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# =============================================================================
# SYSTEM & OS FILES
# =============================================================================

# Windows
Thumbs.db
ehthumbs.db
*.tmp
*.temp
*.bak

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# =============================================================================
# SENSITIVE & CONFIGURATION
# =============================================================================

# Environment files
.env*
!env.template
!*.env.example

# Secrets and keys
secrets.json
credentials.json
*.key
*.pem
*.p12
*.pfx

# Database files
*.db
*.sqlite
*.sqlite3

