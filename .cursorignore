# DEPENDENCY MANAGEMENT
# =============================================================================

# Package manager files
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Pipfile.lock
requirements-lock.txt

# Package manager caches
.npm/
.yarn/
.pnpm-store/

