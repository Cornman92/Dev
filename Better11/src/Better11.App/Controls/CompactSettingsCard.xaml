<!-- Better11 System Enhancement Suite - CompactSettingsCard Control -->
<!-- Dense settings row with icon, title, description, and action slot -->
<UserControl
    x:Class="Better11.App.Controls.CompactSettingsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border x:Name="CardBorder"
            Background="{StaticResource B11CardBackgroundBrush}"
            BorderBrush="{StaticResource B11BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource B11CardCornerRadius}"
            Padding="10,6,10,6"
            Margin="0,1,0,1">
        <Grid MinHeight="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <FontIcon x:Name="CardIcon" Grid.Column="0"
                      FontSize="14"
                      Foreground="{StaticResource B11AccentBrush}"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"/>

            <!-- Title + Description -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                <TextBlock x:Name="TitleText"
                           FontSize="{StaticResource B11FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                <TextBlock x:Name="DescriptionText"
                           FontSize="{StaticResource B11FontSizeCaption}"
                           Foreground="{StaticResource B11TextTertiaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Action Content Slot -->
            <ContentPresenter x:Name="ActionPresenter" Grid.Column="2"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Content="{x:Bind ActionContent, Mode=OneWay}"/>
        </Grid>
    </Border>
</UserControl>
