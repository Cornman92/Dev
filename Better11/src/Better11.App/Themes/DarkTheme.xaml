<!-- Better11 System Enhancement Suite - DarkTheme.xaml -->
<!-- Dense, dark WinUtil-inspired theme resource dictionary -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- PRIMARY PALETTE                                                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="B11PrimaryBackground">#111111</Color>
    <Color x:Key="B11SecondaryBackground">#1A1A1A</Color>
    <Color x:Key="B11TertiaryBackground">#222222</Color>
    <Color x:Key="B11SurfaceBackground">#2A2A2A</Color>
    <Color x:Key="B11CardBackground">#1E1E1E</Color>
    <Color x:Key="B11HoverBackground">#333333</Color>
    <Color x:Key="B11SelectedBackground">#2D2D2D</Color>

    <Color x:Key="B11AccentColor">#0078D4</Color>
    <Color x:Key="B11AccentHover">#1A86D9</Color>
    <Color x:Key="B11AccentPressed">#006CBE</Color>
    <Color x:Key="B11AccentSubtle">#0078D426</Color>

    <Color x:Key="B11TextPrimary">#EEEEEE</Color>
    <Color x:Key="B11TextSecondary">#AAAAAA</Color>
    <Color x:Key="B11TextTertiary">#777777</Color>
    <Color x:Key="B11TextDisabled">#555555</Color>

    <Color x:Key="B11BorderDefault">#333333</Color>
    <Color x:Key="B11BorderSubtle">#2A2A2A</Color>
    <Color x:Key="B11BorderAccent">#0078D4</Color>

    <Color x:Key="B11SuccessColor">#2EA043</Color>
    <Color x:Key="B11WarningColor">#D29922</Color>
    <Color x:Key="B11ErrorColor">#F85149</Color>
    <Color x:Key="B11InfoColor">#58A6FF</Color>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- BRUSHES                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="B11PrimaryBackgroundBrush" Color="{StaticResource B11PrimaryBackground}"/>
    <SolidColorBrush x:Key="B11SecondaryBackgroundBrush" Color="{StaticResource B11SecondaryBackground}"/>
    <SolidColorBrush x:Key="B11TertiaryBackgroundBrush" Color="{StaticResource B11TertiaryBackground}"/>
    <SolidColorBrush x:Key="B11SurfaceBackgroundBrush" Color="{StaticResource B11SurfaceBackground}"/>
    <SolidColorBrush x:Key="B11CardBackgroundBrush" Color="{StaticResource B11CardBackground}"/>
    <SolidColorBrush x:Key="B11HoverBackgroundBrush" Color="{StaticResource B11HoverBackground}"/>
    <SolidColorBrush x:Key="B11SelectedBackgroundBrush" Color="{StaticResource B11SelectedBackground}"/>

    <SolidColorBrush x:Key="B11AccentBrush" Color="{StaticResource B11AccentColor}"/>
    <SolidColorBrush x:Key="B11AccentHoverBrush" Color="{StaticResource B11AccentHover}"/>
    <SolidColorBrush x:Key="B11AccentPressedBrush" Color="{StaticResource B11AccentPressed}"/>
    <SolidColorBrush x:Key="B11AccentSubtleBrush" Color="{StaticResource B11AccentSubtle}"/>

    <SolidColorBrush x:Key="B11TextPrimaryBrush" Color="{StaticResource B11TextPrimary}"/>
    <SolidColorBrush x:Key="B11TextSecondaryBrush" Color="{StaticResource B11TextSecondary}"/>
    <SolidColorBrush x:Key="B11TextTertiaryBrush" Color="{StaticResource B11TextTertiary}"/>
    <SolidColorBrush x:Key="B11TextDisabledBrush" Color="{StaticResource B11TextDisabled}"/>

    <SolidColorBrush x:Key="B11BorderDefaultBrush" Color="{StaticResource B11BorderDefault}"/>
    <SolidColorBrush x:Key="B11BorderSubtleBrush" Color="{StaticResource B11BorderSubtle}"/>
    <SolidColorBrush x:Key="B11BorderAccentBrush" Color="{StaticResource B11BorderAccent}"/>

    <SolidColorBrush x:Key="B11SuccessBrush" Color="{StaticResource B11SuccessColor}"/>
    <SolidColorBrush x:Key="B11WarningBrush" Color="{StaticResource B11WarningColor}"/>
    <SolidColorBrush x:Key="B11ErrorBrush" Color="{StaticResource B11ErrorColor}"/>
    <SolidColorBrush x:Key="B11InfoBrush" Color="{StaticResource B11InfoColor}"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="B11FontSizeCaption">11</x:Double>
    <x:Double x:Key="B11FontSizeBody">13</x:Double>
    <x:Double x:Key="B11FontSizeSubtitle">16</x:Double>
    <x:Double x:Key="B11FontSizeTitle">20</x:Double>
    <x:Double x:Key="B11FontSizeHeader">28</x:Double>
    <x:String x:Key="B11FontFamilyMono">Cascadia Code, Consolas, monospace</x:String>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DENSE LAYOUT CONSTANTS                                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="B11RowHeight">24</x:Double>
    <x:Double x:Key="B11CompactRowHeight">20</x:Double>
    <x:Double x:Key="B11CardPadding">8</x:Double>
    <x:Double x:Key="B11SectionSpacing">12</x:Double>
    <x:Double x:Key="B11ItemSpacing">4</x:Double>
    <x:Double x:Key="B11PagePadding">16</x:Double>
    <Thickness x:Key="B11PageMargin">16,12,16,12</Thickness>
    <Thickness x:Key="B11CardMargin">0,0,0,8</Thickness>
    <Thickness x:Key="B11CardPaddingThickness">10,8,10,8</Thickness>
    <Thickness x:Key="B11ItemMargin">0,2,0,2</Thickness>
    <CornerRadius x:Key="B11CardCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="B11ButtonCornerRadius">2</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- WINUI THEME OVERRIDES                                          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- NavigationView overrides -->
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource B11PrimaryBackground}"/>
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource B11SecondaryBackground}"/>
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{StaticResource B11SecondaryBackground}"/>

    <!-- Page/Window background -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource B11PrimaryBackground}"/>
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource B11PrimaryBackground}"/>

    <!-- Card / Surface styles -->
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource B11CardBackground}"/>
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource B11BorderDefault}"/>

    <!-- Text overrides -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource B11TextPrimary}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource B11TextSecondary}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource B11TextTertiary}"/>
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource B11TextDisabled}"/>

    <!-- Accent overrides -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource B11AccentColor}"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource B11AccentHover}"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource B11AccentPressed}"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DENSE CHECKBOX STYLE                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11DenseCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="MinHeight" Value="{StaticResource B11RowHeight}"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="6,0,0,0"/>
        <Setter Property="FontSize" Value="{StaticResource B11FontSizeBody}"/>
        <Setter Property="Foreground" Value="{StaticResource B11TextPrimaryBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DENSE BUTTON STYLES                                            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11CompactButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="10,4,10,4"/>
        <Setter Property="FontSize" Value="{StaticResource B11FontSizeBody}"/>
        <Setter Property="CornerRadius" Value="{StaticResource B11ButtonCornerRadius}"/>
        <Setter Property="Background" Value="{StaticResource B11SurfaceBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource B11TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B11BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="B11AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource B11CompactButtonStyle}">
        <Setter Property="Background" Value="{StaticResource B11AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource B11AccentBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- DENSE CARD STYLE                                               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11DenseCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource B11CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B11BorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource B11CardCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource B11CardPaddingThickness}"/>
        <Setter Property="Margin" Value="{StaticResource B11CardMargin}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- SECTION HEADER STYLE                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource B11FontSizeSubtitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource B11AccentBrush}"/>
        <Setter Property="Margin" Value="0,8,0,6"/>
    </Style>

    <Style x:Key="B11SectionSubHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource B11FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource B11TextTertiaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- CONSOLE OUTPUT STYLE                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11ConsoleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource B11FontFamilyMono}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource B11TextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- STATUS INDICATOR STYLES                                        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11StatusDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- LISTVIEW DENSE STYLE                                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="B11DenseListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="MinHeight" Value="{StaticResource B11RowHeight}"/>
        <Setter Property="Padding" Value="8,2,8,2"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>

</ResourceDictionary>
