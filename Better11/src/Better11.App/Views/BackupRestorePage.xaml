<Page x:Class="Better11.App.Views.BackupRestorePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource B11PrimaryBackgroundBrush}"
      Loaded="Page_Loaded">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Backup &amp; Restore Manager"
                   FontSize="{StaticResource B11FontSizeTitle}"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource B11TextPrimaryBrush}"/>
        <Pivot Grid.Row="1" Background="{StaticResource B11PrimaryBackgroundBrush}">
            <PivotItem Header="System Restore">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="RpList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SequenceNumber}" Opacity="0.5" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CreationTime}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding RestorePointType}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBox x:Name="RpDescBox" PlaceholderText="Restore point description" MinWidth="300"/>
                        <Button Content="Create" Click="CreateRp_Click"/>
                    </StackPanel>
                </Grid>
            </PivotItem>
            <PivotItem Header="Registry">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="RegList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding KeyPath}" Opacity="0.7" TextTrimming="CharacterEllipsis" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeKb}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="RegKeyBox" PlaceholderText="Registry key path" MinWidth="300"/>
                            <TextBox x:Name="RegNameBox" PlaceholderText="Backup name" MinWidth="120"/>
                            <Button Content="Export" Click="ExportReg_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <TextBox x:Name="RegImportBox" PlaceholderText="Import file path" MinWidth="300"/>
                            <Button Content="Import" Click="ImportReg_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </PivotItem>
            <PivotItem Header="File Backup">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="BkpList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SourcePath}" Opacity="0.7" TextTrimming="CharacterEllipsis" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeMb}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Compressed}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Encrypted}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox x:Name="SrcBox" PlaceholderText="Source folder" MinWidth="200"/>
                            <TextBox x:Name="DstBox" PlaceholderText="Destination" MinWidth="200"/>
                            <ToggleSwitch x:Name="CompressSwitch" Header="Compress"/>
                            <ToggleSwitch x:Name="EncryptSwitch" Header="Encrypt"/>
                            <Button Content="Backup" Click="CreateBkp_Click" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </PivotItem>
            <PivotItem Header="Schedules">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="SchedList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Frequency}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RetentionDays}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding NextRun}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <Button Grid.Column="4" Content="Del" Click="DeleteSched_Click" Tag="{Binding Name}" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBox x:Name="SchedNameBox" PlaceholderText="Schedule name" MinWidth="120"/>
                        <ComboBox x:Name="FreqBox" SelectedIndex="0" MinWidth="100">
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Monthly"/>
                        </ComboBox>
                        <NumberBox x:Name="RetBox" Header="Retention" Value="30" Minimum="1" Maximum="365" SpinButtonPlacementMode="Inline" MinWidth="80"/>
                        <Button Content="Create Schedule" Click="CreateSched_Click" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>
            </PivotItem>
        </Pivot>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="16" Height="16"/>
            <TextBlock x:Name="StatusText" Opacity="0.7" VerticalAlignment="Center" Foreground="{StaticResource B11TextTertiaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
