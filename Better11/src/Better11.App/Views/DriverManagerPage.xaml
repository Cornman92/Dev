<!-- Better11 System Enhancement Suite - DriverManagerPage.xaml -->
<!-- Dense WinUtil-inspired driver manager with scan, update, backup, and export -->
<Page
    x:Class="Better11.App.Views.DriverManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE964;" FontSize="20"
                          Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.ScanDriversCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE9D9;" FontSize="12"/>
                        <TextBlock Text="Scan Drivers"/>
                    </StackPanel>
                </Button>
                <Button Content="Refresh"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,6">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- SUMMARY CARDS                                                  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource B11DenseCardStyle}" Margin="0,0,4,0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Total" FontSize="{StaticResource B11FontSizeCaption}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalDrivers, Mode=OneWay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource B11TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource B11DenseCardStyle}" Margin="2,0,2,0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Up to Date" FontSize="{StaticResource B11FontSizeCaption}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.UpToDateCount, Mode=OneWay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource B11SuccessBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource B11DenseCardStyle}" Margin="2,0,2,0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Updates Available" FontSize="{StaticResource B11FontSizeCaption}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.UpdatesAvailableCount, Mode=OneWay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource B11WarningBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource B11DenseCardStyle}" Margin="4,0,0,0">
                <StackPanel Spacing="2">
                    <TextBlock Text="Problems" FontSize="{StaticResource B11FontSizeCaption}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ProblemCount, Mode=OneWay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource B11ErrorBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- COLUMN HEADERS                                                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Style="{StaticResource B11DenseCardStyle}"
                Margin="0,0,0,2" Padding="8,4,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{x:Bind ViewModel.IsAllSelected, Mode=TwoWay}"
                          MinWidth="0" MinHeight="0" Padding="0"
                          ToolTipService.ToolTip="Select All"/>
                <TextBlock Grid.Column="1" Text="Driver Name"
                           FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="Version"
                           FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="Provider"
                           FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Text="Date"
                           FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
                <TextBlock Grid.Column="5" Text="Status"
                           FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- DRIVER LIST                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ListView Grid.Row="4"
                  ItemsSource="{x:Bind ViewModel.Drivers, Mode=OneWay}"
                  SelectionMode="None"
                  Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource B11DenseListViewItemStyle}">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource B11BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,2,0,2">
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      MinWidth="0" MinHeight="0" Padding="0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding DeviceClass}"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding Version}"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       FontFamily="{StaticResource B11FontFamilyMono}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="3" Text="{Binding Provider}"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="4" Text="{Binding Date}"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontFamily="{StaticResource B11FontFamilyMono}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="5" Orientation="Horizontal"
                                        VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding StatusColor}"
                                         Style="{StaticResource B11StatusDotStyle}"/>
                                <TextBlock Text="{Binding Status}"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM ACTION BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="5" Style="{StaticResource B11DenseCardStyle}"
                Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11AccentBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="drivers selected"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Style="{StaticResource B11AccentButtonStyle}"
                            Command="{x:Bind ViewModel.UpdateSelectedCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE896;" FontSize="12"/>
                            <TextBlock Text="Update Selected"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource B11CompactButtonStyle}"
                            Command="{x:Bind ViewModel.BackupAllCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8F1;" FontSize="12"/>
                            <TextBlock Text="Backup All"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource B11CompactButtonStyle}"
                            Command="{x:Bind ViewModel.ExportCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                            <TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
