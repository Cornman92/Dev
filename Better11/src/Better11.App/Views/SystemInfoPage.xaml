<!-- Better11 System Enhancement Suite - SystemInfoPage.xaml -->
<!-- Dense WinUtil-inspired system information display with compact info grids -->
<Page
    x:Class="Better11.App.Views.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE7F4;" FontSize="20" Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Style="{StaticResource B11CompactButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                        <TextBlock Text="Export"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource B11CompactButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                        <TextBlock Text="Copy"/>
                    </StackPanel>
                </Button>
                <Button Content="Refresh"
                        Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.LoadDataCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,8">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}">

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- OPERATING SYSTEM                                       -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Operating System" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="1">
                        <!-- OS Name -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="OS Name"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Windows 11 Pro"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Version -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="24H2"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Build -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Build"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="26200.5516"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       FontFamily="{StaticResource B11FontFamilyMono}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Architecture -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Architecture"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="x64"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Install Date -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Install Date"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="--"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Uptime -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Uptime"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="--"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- HARDWARE — 2 column layout                             -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ─── CPU ─── -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Processor" Style="{StaticResource B11SectionHeaderStyle}"/>
                        <Border Style="{StaticResource B11DenseCardStyle}">
                            <StackPanel Spacing="1">
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="CPU"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Cores"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Threads"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Base Clock"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontFamily="{StaticResource B11FontFamilyMono}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ─── GPU ─── -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock Text="Graphics" Style="{StaticResource B11SectionHeaderStyle}"/>
                        <Border Style="{StaticResource B11DenseCardStyle}">
                            <StackPanel Spacing="1">
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="VRAM"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Driver"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontFamily="{StaticResource B11FontFamilyMono}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Resolution"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ─── RAM ─── -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Memory" Style="{StaticResource B11SectionHeaderStyle}"/>
                        <Border Style="{StaticResource B11DenseCardStyle}">
                            <StackPanel Spacing="1">
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Total RAM"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Speed"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Type"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Slots Used"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- ─── Disk ─── -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock Text="Storage" Style="{StaticResource B11SectionHeaderStyle}"/>
                        <Border Style="{StaticResource B11DenseCardStyle}">
                            <StackPanel Spacing="1">
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Drive"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Capacity"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Free Space"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                                <Grid MinHeight="{StaticResource B11RowHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Interface"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="--"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- NETWORK                                                -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Network" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="1">
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Adapter"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="IPv4 Address"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           FontFamily="{StaticResource B11FontFamilyMono}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="1" Margin="12,0,0,0">
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MAC Address"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           FontFamily="{StaticResource B11FontFamilyMono}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="DNS Servers"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           FontFamily="{StaticResource B11FontFamilyMono}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- MOTHERBOARD & BIOS                                     -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Motherboard &amp; BIOS" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="1">
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Manufacturer"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Model"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="1" Margin="12,0,0,0">
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="BIOS Version"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           FontFamily="{StaticResource B11FontFamilyMono}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>
                            <Grid MinHeight="{StaticResource B11RowHeight}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Secure Boot"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="--"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
