<Page x:Class="Better11.App.Views.UserAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource B11PrimaryBackgroundBrush}"
    Loaded="Page_Loaded">
    <Grid Padding="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="User Account Manager"
                       FontSize="{StaticResource B11FontSizeTitle}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
            <TextBlock x:Name="SummaryText"
                       FontSize="{StaticResource B11FontSizeCaption}"
                       Foreground="{StaticResource B11TextSecondaryBrush}"
                       Opacity="0.7"/>
        </StackPanel>
        <Pivot Grid.Row="1" Background="{StaticResource B11PrimaryBackgroundBrush}">
            <PivotItem Header="Accounts">
                <Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <ListView x:Name="AccountList" SelectionMode="None">
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/><ColumnDefinition Width="120"/><ColumnDefinition Width="60"/><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Username}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FullName}" Opacity="0.7" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding Enabled}" Opacity="0.5" FontSize="12" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="{Binding IsAdmin}" Opacity="0.5" FontSize="12" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="{Binding LastLogin}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                            <Button Content="Toggle" Click="ToggleAccount_Click" Tag="{Binding Username}" FontSize="11"/>
                            <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Click="DeleteAccount_Click" Tag="{Binding Username}"/>
                        </StackPanel></Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBox x:Name="NewUserBox" PlaceholderText="Username" MinWidth="120"/>
                        <PasswordBox x:Name="NewPassBox" PlaceholderText="Password" MinWidth="120"/>
                        <TextBox x:Name="NewFullNameBox" PlaceholderText="Full Name" MinWidth="120"/>
                        <Button Content="Create" Click="CreateAccount_Click"/>
                    </StackPanel>
                </Grid>
            </PivotItem>
            <PivotItem Header="Groups">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <ListView Grid.Row="0" x:Name="GroupList" SelectionMode="Single" MaxHeight="150" SelectionChanged="GroupList_SelectionChanged">
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Description}" Opacity="0.7" TextTrimming="CharacterEllipsis" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding MemberCount}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        </Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                    <ListView Grid.Row="1" x:Name="MemberList" SelectionMode="None">
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ObjectClass}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding Sid}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <Button Grid.Column="3" Content="Remove" Click="RemoveMember_Click" Tag="{Binding Name}" FontSize="11"/>
                        </Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <TextBox x:Name="MemberUserBox" PlaceholderText="Username to add" MinWidth="200"/>
                        <Button Content="Add Member" Click="AddMember_Click"/>
                    </StackPanel>
                </Grid>
            </PivotItem>
            <PivotItem Header="Policy &amp; Login">
                <ScrollViewer><StackPanel Spacing="12" Margin="0,8,0,0">
                    <TextBlock Text="Password Policy" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumberBox x:Name="MinLenBox" Header="Min Length" Minimum="0" Maximum="128" SpinButtonPlacementMode="Inline" MinWidth="100"/>
                        <NumberBox x:Name="MaxAgeBox" Header="Max Age (days)" Minimum="0" Maximum="999" SpinButtonPlacementMode="Inline" MinWidth="100"/>
                        <ToggleSwitch x:Name="ComplexitySwitch" Header="Complexity"/>
                        <Button Content="Apply Policy" Click="ApplyPolicy_Click" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock x:Name="LockoutText" Opacity="0.7" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    <TextBlock Text="Auto-Login"
                               FontSize="{StaticResource B11FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource B11TextPrimaryBrush}"
                               Margin="0,16,0,0"/>
                    <TextBlock x:Name="AutoLoginText" Opacity="0.7" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="AutoUserBox" PlaceholderText="Username" MinWidth="150"/>
                        <PasswordBox x:Name="AutoPassBox" PlaceholderText="Password" MinWidth="150"/>
                        <Button Content="Enable" Click="SetAutoLogin_Click"/>
                        <Button Content="Disable" Click="DisableAutoLogin_Click"/>
                    </StackPanel>
                </StackPanel></ScrollViewer>
            </PivotItem>
            <PivotItem Header="Profiles">
                <ListView x:Name="ProfileList" SelectionMode="None">
                    <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Username}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProfilePath}" Opacity="0.7" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding SizeMb}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="{Binding IsLoaded}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    </Grid></DataTemplate></ListView.ItemTemplate>
                </ListView>
            </PivotItem>
            <PivotItem Header="Audit &amp; Sessions">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Button Content="Load Security Audit" Click="LoadAudit_Click" Margin="0,8,0,4"/>
                    <ListView Grid.Row="1" x:Name="AuditList" SelectionMode="None" MaxHeight="200">
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/><ColumnDefinition Width="100"/><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding EventType}" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding AccountName}" Opacity="0.7" FontSize="11" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="{Binding Result}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        </Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                    <Button Grid.Row="2" Content="Load Sessions" Click="LoadSessions_Click" Margin="0,8,0,4"/>
                    <ListView Grid.Row="3" x:Name="SessionList" SelectionMode="None">
                        <ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="8"><Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/><ColumnDefinition Width="120"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SessionId}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Username}" FontWeight="SemiBold" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="{Binding State}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="{Binding SessionType}" Opacity="0.5" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="{Binding LogonTime}" Opacity="0.5" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <Button Grid.Column="5" Content="Logoff" Click="LogoffSession_Click" Tag="{Binding SessionId}" FontSize="11"/>
                        </Grid></DataTemplate></ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="16" Height="16"/>
            <TextBlock x:Name="StatusText" Opacity="0.7" VerticalAlignment="Center" Foreground="{StaticResource B11TextTertiaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
