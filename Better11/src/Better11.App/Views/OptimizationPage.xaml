<!-- Better11 System Enhancement Suite - OptimizationPage.xaml -->
<!-- Data-driven optimization page backed by live tweak categories -->
<Page
    x:Class="Better11.App.Views.OptimizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE9D5;" FontSize="20" Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{Binding PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Content="Apply Selected"
                        Style="{StaticResource B11AccentButtonStyle}"
                        Command="{Binding ApplyOptimizationsCommand}"/>
                <Button Content="Restore Point"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{Binding CreateRestorePointCommand}"/>
                <Button Content="Reload Catalog"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{Binding LoadCategoriesCommand}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,8">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsBusy}"
                         Height="2"/>
            <InfoBar IsOpen="{Binding HasError}"
                     Severity="Error"
                     Title="Error"
                     Message="{Binding ErrorMessage}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{Binding HasSuccess}"
                     Severity="Success"
                     Title="Success"
                     Message="{Binding SuccessMessage}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{Binding RebootRequired}"
                     Severity="Warning"
                     Title="Reboot Required"
                     Message="Some optimizations require a system reboot to take effect."
                     IsClosable="False"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8F1;" FontSize="14" Foreground="{StaticResource B11AccentBrush}"/>
                            <TextBlock Text="Live Optimization Catalog"
                                       Style="{StaticResource B11SectionHeaderStyle}"
                                       Margin="0"/>
                        </StackPanel>
                        <TextBlock Text="This page now reflects the optimization service directly. Pending tweaks are preselected; already-applied tweaks stay visible for audit."
                                   Style="{StaticResource B11SectionSubHeaderStyle}"
                                   TextWrapping="Wrap"/>

                        <ItemsRepeater ItemsSource="{Binding Categories}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource B11DenseCardStyle}"
                                            Background="{StaticResource B11SecondaryBackgroundBrush}"
                                            BorderBrush="{StaticResource B11BorderDefaultBrush}">
                                        <StackPanel Spacing="8">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource B11SectionHeaderStyle}"
                                                           Margin="0"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource B11SectionSubHeaderStyle}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <ItemsRepeater ItemsSource="{Binding Tweaks}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="6"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource B11PrimaryBackgroundBrush}"
                                                                BorderBrush="{StaticResource B11BorderDefaultBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="10,8">
                                                            <Grid ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0" Spacing="4">
                                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                              Style="{StaticResource B11DenseCheckBoxStyle}">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontSize="{StaticResource B11FontSizeBody}"
                                                                                   Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                                                    </CheckBox>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Margin="24,0,0,0"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                                                               FontSize="{StaticResource B11FontSizeCaption}"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="1"
                                                                            Spacing="4"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top">
                                                                    <TextBlock Text="{Binding RiskLevel}"
                                                                               FontSize="{StaticResource B11FontSizeCaption}"
                                                                               Foreground="{StaticResource B11AccentBrush}"
                                                                               HorizontalAlignment="Right"/>
                                                                    <TextBlock Text="{Binding StatusText}"
                                                                               FontSize="{StaticResource B11FontSizeCaption}"
                                                                               Foreground="{StaticResource B11TextTertiaryBrush}"
                                                                               HorizontalAlignment="Right"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource B11DenseCardStyle}"
                        Background="{StaticResource B11PrimaryBackgroundBrush}"
                        BorderBrush="{StaticResource B11BorderDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                            <FontIcon Glyph="&#xE756;" FontSize="12" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            <TextBlock Text="Execution Status"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="160"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{StaticResource B11PrimaryBackgroundBrush}">
                            <StackPanel Spacing="4" Padding="4">
                                <TextBlock Style="{StaticResource B11ConsoleTextStyle}"
                                           Text="[Catalog] Select pending tweaks and apply when ready."/>
                                <TextBlock Style="{StaticResource B11ConsoleTextStyle}"
                                           Text="{Binding LoadingMessage}"/>
                                <TextBlock Style="{StaticResource B11ConsoleTextStyle}"
                                           Text="{Binding SuccessMessage}"/>
                                <TextBlock Style="{StaticResource B11ConsoleTextStyle}"
                                           Text="{Binding ErrorMessage}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
