<!-- Better11 System Enhancement Suite - SettingsPage.xaml -->
<!-- Dense WinUtil-inspired application settings with compact rows and grouped sections -->
<Page
    x:Class="Better11.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <Button Grid.Column="1" Style="{StaticResource B11AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SaveSettingsCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="12"/>
                    <TextBlock Text="Save Settings"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,8">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}">

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- THEME SELECTION                                        -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Appearance" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <!-- Theme -->
                        <Grid MinHeight="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="App Theme"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Choose between dark, light, or system default"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center">
                                <RadioButton Content="Dark" GroupName="Theme"
                                             FontSize="{StaticResource B11FontSizeBody}"
                                             MinHeight="0" MinWidth="0" Padding="6,2,6,2"/>
                                <RadioButton Content="Light" GroupName="Theme"
                                             FontSize="{StaticResource B11FontSizeBody}"
                                             MinHeight="0" MinWidth="0" Padding="6,2,6,2"/>
                                <RadioButton Content="System" GroupName="Theme" IsChecked="True"
                                             FontSize="{StaticResource B11FontSizeBody}"
                                             MinHeight="0" MinWidth="0" Padding="6,2,6,2"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- GENERAL SETTINGS                                       -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="General" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <!-- Auto-refresh -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Auto-refresh data"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Automatically refresh page data on navigation"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.AutoUpdateEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Notifications -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Show notifications"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Display toast notifications for completed operations"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="True"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Telemetry -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Send anonymous usage data"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}">
                                    <Run Text="Help improve Better11 by sharing anonymous usage statistics. "/>
                                    <Hyperlink NavigateUri="https://docs.better11.app/privacy"
                                               UnderlineStyle="Single"
                                               Click="PrivacyPolicyLink_Click">
                                        <Run Text="Privacy policy"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsOn="{x:Bind ViewModel.TelemetryEnabled, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Log level -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Log level"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Verbosity of application logging output"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="1"
                                      MinWidth="120" Height="28"
                                      FontSize="{StaticResource B11FontSizeBody}"
                                      VerticalAlignment="Center"
                                      Background="{StaticResource B11SurfaceBackgroundBrush}"
                                      BorderBrush="{StaticResource B11BorderDefaultBrush}">
                                <ComboBoxItem Content="Verbose"/>
                                <ComboBoxItem Content="Information"/>
                                <ComboBoxItem Content="Warning"/>
                                <ComboBoxItem Content="Error"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- POWERSHELL SETTINGS                                    -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="PowerShell" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <!-- Execution Policy -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Execution policy"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="PowerShell script execution policy for Better11 modules"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="1"
                                      MinWidth="140" Height="28"
                                      FontSize="{StaticResource B11FontSizeBody}"
                                      VerticalAlignment="Center"
                                      Background="{StaticResource B11SurfaceBackgroundBrush}"
                                      BorderBrush="{StaticResource B11BorderDefaultBrush}">
                                <ComboBoxItem Content="Restricted"/>
                                <ComboBoxItem Content="RemoteSigned"/>
                                <ComboBoxItem Content="Unrestricted"/>
                                <ComboBoxItem Content="Bypass"/>
                            </ComboBox>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Module path -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Module path"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Root path for Better11 PowerShell modules"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBox Text=".\src" MinWidth="160" Height="28"
                                         FontSize="{StaticResource B11FontSizeBody}"
                                         FontFamily="{StaticResource B11FontFamilyMono}"
                                         Background="{StaticResource B11SurfaceBackgroundBrush}"
                                         BorderBrush="{StaticResource B11BorderDefaultBrush}"
                                         Padding="6,3,6,3"/>
                                <Button Content="Browse" Style="{StaticResource B11CompactButtonStyle}"
                                        Height="28"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- PowerShell version -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PowerShell version"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Preferred PowerShell runtime version"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" SelectedIndex="0"
                                      MinWidth="140" Height="28"
                                      FontSize="{StaticResource B11FontSizeBody}"
                                      VerticalAlignment="Center"
                                      Background="{StaticResource B11SurfaceBackgroundBrush}"
                                      BorderBrush="{StaticResource B11BorderDefaultBrush}">
                                <ComboBoxItem Content="PowerShell 7.x"/>
                                <ComboBoxItem Content="Windows PowerShell 5.1"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- ABOUT                                                  -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="About" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <!-- Version -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Version"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="1.0.0-preview"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       FontFamily="{StaticResource B11FontFamilyMono}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Framework -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Framework"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text=".NET 8 / WinUI 3"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Author -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Author"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Better11 Team"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- License -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="License"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="MIT License"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Links -->
                        <Grid MinHeight="{StaticResource B11RowHeight}" Margin="0,4,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Links"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <HyperlinkButton Content="GitHub" Padding="0"
                                                 FontSize="{StaticResource B11FontSizeBody}"
                                                 Foreground="{StaticResource B11AccentBrush}"/>
                                <TextBlock Text="|" FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <HyperlinkButton Content="Documentation" Padding="0"
                                                 FontSize="{StaticResource B11FontSizeBody}"
                                                 Foreground="{StaticResource B11AccentBrush}"/>
                                <TextBlock Text="|" FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <HyperlinkButton Content="Report Issue" Padding="0"
                                                 FontSize="{StaticResource B11FontSizeBody}"
                                                 Foreground="{StaticResource B11AccentBrush}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Credits -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Credits"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Inspired by Chris Titus Tech's WinUtil"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── First Run Wizard ─── -->
                <TextBlock Text="First Run Wizard" Style="{StaticResource B11SectionHeaderStyle}"/>
                <Border Style="{StaticResource B11DenseCardStyle}">
                    <Grid MinHeight="{StaticResource B11RowHeight}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Run wizard again"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="Reset wizard state so it appears on next launch, or open it from the navigation footer."
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Run Wizard Again"
                                Command="{x:Bind ViewModel.ResetFirstRunCommand}"
                                Style="{StaticResource B11AccentButtonStyle}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ─── Reset / Danger Zone ─── -->
                <TextBlock Text="Danger Zone" Style="{StaticResource B11SectionHeaderStyle}"
                           Foreground="{StaticResource B11ErrorBrush}"/>

                <Border Style="{StaticResource B11DenseCardStyle}"
                        BorderBrush="{StaticResource B11ErrorBrush}">
                    <Grid MinHeight="{StaticResource B11RowHeight}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Reset all settings"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="Restore all settings to their default values. This cannot be undone."
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Reset All"
                                Style="{StaticResource B11CompactButtonStyle}"
                                Foreground="{StaticResource B11ErrorBrush}"
                                BorderBrush="{StaticResource B11ErrorBrush}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
