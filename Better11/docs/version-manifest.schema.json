{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Better11 Version Manifest",
  "description": "JSON manifest used by the app to check for updates",
  "type": "object",
  "required": [ "version" ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of the release (e.g. 1.1.0)"
    },
    "downloadUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL to the MSIX or installer package"
    },
    "releaseNotes": {
      "type": "string",
      "description": "Optional release notes or description"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 publish date"
    }
  }
}
