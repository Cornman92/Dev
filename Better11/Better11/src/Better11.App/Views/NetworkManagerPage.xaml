<!-- Better11 System Enhancement Suite - NetworkManagerPage.xaml -->
<!-- Dense WinUtil-inspired network manager with adapter cards, DNS, and firewall toggles -->
<Page
    x:Class="Better11.App.Views.NetworkManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE968;" FontSize="20"
                          Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Content="Refresh"
                        Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}"/>
                <Button Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.ResetNetworkCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        <TextBlock Text="Reset Stack"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,6">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- SCROLLABLE CONTENT                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}">

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- NETWORK ADAPTERS                                       -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Network Adapters"
                           Style="{StaticResource B11SectionHeaderStyle}"/>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Adapters, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="6"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource B11DenseCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Adapter Icon + Status -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                                Margin="0,0,12,0" Spacing="4">
                                        <FontIcon Glyph="&#xE839;" FontSize="24"
                                                  Foreground="{StaticResource B11AccentBrush}"
                                                  HorizontalAlignment="Center"/>
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{Binding StatusColor}"
                                                 HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Adapter Details -->
                                    <Grid Grid.Column="1" RowSpacing="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Row 1: Name + Status -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                    Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource B11FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                            <Border Background="{Binding StatusBackground}"
                                                    CornerRadius="2" Padding="6,1,6,1">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="{StaticResource B11FontSizeCaption}"
                                                           Foreground="{Binding StatusForeground}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Row 2: IP, MAC, Speed -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="0">
                                            <TextBlock Text="IP Address"
                                                       FontSize="{StaticResource B11FontSizeCaption}"
                                                       Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       FontSize="{StaticResource B11FontSizeBody}"
                                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                                       FontFamily="{StaticResource B11FontFamilyMono}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="0">
                                            <TextBlock Text="MAC Address"
                                                       FontSize="{StaticResource B11FontSizeCaption}"
                                                       Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding MacAddress}"
                                                       FontSize="{StaticResource B11FontSizeBody}"
                                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                                       FontFamily="{StaticResource B11FontFamilyMono}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="0">
                                            <TextBlock Text="Speed"
                                                       FontSize="{StaticResource B11FontSizeCaption}"
                                                       Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                            <TextBlock Text="{Binding Speed}"
                                                       FontSize="{StaticResource B11FontSizeBody}"
                                                       Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Adapter Actions -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                        <Button Style="{StaticResource B11CompactButtonStyle}"
                                                Content="Details" Height="24"
                                                FontSize="{StaticResource B11FontSizeCaption}"
                                                Command="{Binding ShowDetailsCommand}"/>
                                        <Button Style="{StaticResource B11CompactButtonStyle}"
                                                Content="Disable" Height="24"
                                                FontSize="{StaticResource B11FontSizeCaption}"
                                                Command="{Binding ToggleCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- DNS SETTINGS                                           -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="DNS Configuration"
                           Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Quick DNS Presets"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                   Margin="0,0,0,2"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cloudflare (1.1.1.1)"
                                    Style="{StaticResource B11CompactButtonStyle}"
                                    HorizontalAlignment="Stretch" Margin="0,0,3,0"
                                    Command="{x:Bind ViewModel.SetDnsCommand}"
                                    CommandParameter="Cloudflare"/>
                            <Button Grid.Column="1" Content="Google (8.8.8.8)"
                                    Style="{StaticResource B11CompactButtonStyle}"
                                    HorizontalAlignment="Stretch" Margin="1,0,2,0"
                                    Command="{x:Bind ViewModel.SetDnsCommand}"
                                    CommandParameter="Google"/>
                            <Button Grid.Column="2" Content="Quad9 (9.9.9.9)"
                                    Style="{StaticResource B11CompactButtonStyle}"
                                    HorizontalAlignment="Stretch" Margin="2,0,1,0"
                                    Command="{x:Bind ViewModel.SetDnsCommand}"
                                    CommandParameter="Quad9"/>
                            <Button Grid.Column="3" Content="DHCP (Auto)"
                                    Style="{StaticResource B11CompactButtonStyle}"
                                    HorizontalAlignment="Stretch" Margin="3,0,0,0"
                                    Command="{x:Bind ViewModel.SetDnsCommand}"
                                    CommandParameter="DHCP"/>
                        </Grid>

                        <Border BorderBrush="{StaticResource B11BorderSubtleBrush}"
                                BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,6,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="DNS Options"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                <CheckBox Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Enable DNS over HTTPS (DoH)"
                                          IsChecked="{x:Bind ViewModel.IsDnsOverHttpsEnabled, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Flush DNS cache on change"
                                          IsChecked="{x:Bind ViewModel.IsFlushDnsOnChange, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Disable Smart Multi-Homed Name Resolution"
                                          IsChecked="{x:Bind ViewModel.IsSmartMultiHomedDisabled, Mode=TwoWay}"/>
                                <CheckBox Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Disable NetBIOS over TCP/IP"
                                          IsChecked="{x:Bind ViewModel.IsNetBiosDisabled, Mode=TwoWay}"/>
                            </StackPanel>
                        </Border>

                        <!-- Current DNS Info -->
                        <Border BorderBrush="{StaticResource B11BorderSubtleBrush}"
                                BorderThickness="0,1,0,0" Margin="0,2,0,0" Padding="0,6,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="0">
                                    <TextBlock Text="Primary DNS"
                                               FontSize="{StaticResource B11FontSizeCaption}"
                                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PrimaryDns, Mode=OneWay}"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontFamily="{StaticResource B11FontFamilyMono}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="0">
                                    <TextBlock Text="Secondary DNS"
                                               FontSize="{StaticResource B11FontSizeCaption}"
                                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SecondaryDns, Mode=OneWay}"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               FontFamily="{StaticResource B11FontFamilyMono}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- FIREWALL QUICK TOGGLES                                 -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <TextBlock Text="Firewall"
                           Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="6">
                        <!-- Firewall Status Indicator -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="10" Height="10"
                                         Fill="{x:Bind ViewModel.FirewallStatusColor, Mode=OneWay}"/>
                                <TextBlock Text="{x:Bind ViewModel.FirewallStatusText, Mode=OneWay}"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource B11CompactButtonStyle}"
                                    Command="{x:Bind ViewModel.OpenFirewallSettingsCommand}"
                                    Content="Advanced Settings"/>
                        </Grid>

                        <Border BorderBrush="{StaticResource B11BorderSubtleBrush}"
                                BorderThickness="0,1,0,0" Margin="0,2,0,0" Padding="0,6,0,0">
                            <Grid RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Domain Profile"
                                          IsChecked="{x:Bind ViewModel.IsDomainFirewallEnabled, Mode=TwoWay}"/>
                                <CheckBox Grid.Row="0" Grid.Column="1"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Private Profile"
                                          IsChecked="{x:Bind ViewModel.IsPrivateFirewallEnabled, Mode=TwoWay}"/>
                                <CheckBox Grid.Row="1" Grid.Column="0"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Public Profile"
                                          IsChecked="{x:Bind ViewModel.IsPublicFirewallEnabled, Mode=TwoWay}"/>
                                <CheckBox Grid.Row="1" Grid.Column="1"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Block inbound by default"
                                          IsChecked="{x:Bind ViewModel.IsBlockInboundEnabled, Mode=TwoWay}"/>
                                <CheckBox Grid.Row="2" Grid.Column="0"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Log dropped packets"
                                          IsChecked="{x:Bind ViewModel.IsLogDroppedEnabled, Mode=TwoWay}"/>
                                <CheckBox Grid.Row="2" Grid.Column="1"
                                          Style="{StaticResource B11DenseCheckBoxStyle}"
                                          Content="Disable Teredo tunneling"
                                          IsChecked="{x:Bind ViewModel.IsTeredoDisabled, Mode=TwoWay}"/>
                            </Grid>
                        </Border>

                        <!-- Apply Button -->
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    HorizontalAlignment="Right" Margin="0,4,0,0">
                            <Button Style="{StaticResource B11AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.ApplyFirewallCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE73E;" FontSize="12"/>
                                    <TextBlock Text="Apply Changes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource B11CompactButtonStyle}"
                                    Content="Reset Defaults"
                                    Command="{x:Bind ViewModel.ResetFirewallCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
