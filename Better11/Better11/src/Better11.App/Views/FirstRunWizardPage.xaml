<!-- Better11 System Enhancement Suite - FirstRunWizardPage.xaml -->
<!-- Multi-step first run wizard: Welcome -> Scan -> Config -> Select -> Apply -> Complete -->
<Page
    x:Class="Better11.App.Views.FirstRunWizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step Indicator Bar -->
        <Border Grid.Row="0" Background="{StaticResource B11SecondaryBackgroundBrush}" Padding="16,8,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Step Dots -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11AccentBrush}"/>
                        <TextBlock Text="Welcome" FontSize="11" Foreground="{StaticResource B11TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text=">" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="Scan" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text=">" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="Config" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text=">" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="Select" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text=">" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="Apply" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text=">" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="Done" FontSize="11" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Skip Button -->
                <Button Grid.Column="1" Content="Skip Wizard"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.SkipCommand}"
                        Height="24" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Content Area (step-switched) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="{StaticResource B11PageMargin}">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}" MaxWidth="700" HorizontalAlignment="Center">

                <!-- Step Title -->
                <StackPanel Spacing="4" Margin="0,8,0,12">
                    <TextBlock Text="{x:Bind ViewModel.StepTitle, Mode=OneWay}"
                               FontSize="{StaticResource B11FontSizeTitle}"
                               FontWeight="Bold"
                               Foreground="{StaticResource B11TextPrimaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.StepDescription, Mode=OneWay}"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Error Bar -->
                <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                         Severity="Error" Title="Error"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="True"/>

                <!-- Step 0: Welcome -->
                <Border Style="{StaticResource B11DenseCardStyle}" Padding="20,16,20,16">
                    <StackPanel Spacing="12" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE770;" FontSize="48"
                                  Foreground="{StaticResource B11AccentBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Better11" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource B11TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="System Enhancement Suite" FontSize="14"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="{StaticResource B11FontSizeBody}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                   MaxWidth="500"
                                   Text="This wizard will scan your system, recommend optimizations based on your usage pattern, and let you choose exactly which tweaks to apply. You can always change settings later."/>
                    </StackPanel>
                </Border>

                <!-- Step 1: System Scan Results -->
                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="System Detection" Style="{StaticResource B11SectionHeaderStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.ScanProgress, Mode=OneWay}"
                                     Maximum="100" Height="4"
                                     Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OS" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.OsVersion, Mode=OneWay}" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            </Grid>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="CPU" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.CpuName, Mode=OneWay}" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            </Grid>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RAM" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.RamAmount, Mode=OneWay}" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            </Grid>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GPU" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.GpuName, Mode=OneWay}" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 2: Preset Selection -->
                <TextBlock Text="Choose Your Profile" Style="{StaticResource B11SectionHeaderStyle}"/>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Presets}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource B11DenseCardStyle}" Padding="12,8,12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton Grid.Column="0" GroupName="Preset" Margin="0,0,8,0"
                                                 MinHeight="0" MinWidth="0"/>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="{Binding Icon}" FontSize="14"
                                                      Foreground="{StaticResource B11AccentBrush}"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       FontSize="{StaticResource B11FontSizeBody}"
                                                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="{StaticResource B11FontSizeCaption}"
                                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Step 3: Module Selection -->
                <TextBlock Text="Select Modules" Style="{StaticResource B11SectionHeaderStyle}"/>
                <TextBlock FontSize="{StaticResource B11FontSizeCaption}"
                           Foreground="{StaticResource B11TextTertiaryBrush}">
                    <Run Text="Selected: "/>
                    <Run Text="{x:Bind ViewModel.SelectedModuleCount, Mode=OneWay}"/>
                    <Run Text=" modules"/>
                </TextBlock>
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Modules}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="300" MinItemHeight="28"
                                           MinRowSpacing="2" MinColumnSpacing="4"
                                           ItemsStretch="Fill"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Style="{StaticResource B11DenseCheckBoxStyle}"
                                      ToolTipService.ToolTip="{Binding Description}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Category}" FontSize="10"
                                               Foreground="{StaticResource B11TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Step 4: Applying -->
                <Border Style="{StaticResource B11DenseCardStyle}" Padding="16,12,16,12">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <ProgressRing IsActive="{x:Bind ViewModel.IsApplying, Mode=OneWay}"
                                      Width="40" Height="40"/>
                        <TextBlock Text="{x:Bind ViewModel.ApplyStatus, Mode=OneWay}"
                                   FontSize="{StaticResource B11FontSizeBody}"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar Value="{x:Bind ViewModel.ApplyProgress, Mode=OneWay}"
                                     Maximum="100" Height="4"/>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}">
                            <Run Text="{x:Bind ViewModel.AppliedCount, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{x:Bind ViewModel.TotalToApply, Mode=OneWay}"/>
                            <Run Text=" modules"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Step 5: Complete -->
                <Border Style="{StaticResource B11DenseCardStyle}" Padding="20,16,20,16">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;" FontSize="48"
                                  Foreground="{StaticResource B11SuccessBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="All Done!" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource B11TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Better11 is configured and ready to use."
                                   FontSize="{StaticResource B11FontSizeBody}"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="You can change any of these settings from the sidebar at any time."
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Navigation Bar -->
        <Border Grid.Row="2" Background="{StaticResource B11SecondaryBackgroundBrush}" Padding="16,8,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Back"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.GoBackCommand}"
                        Visibility="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"/>

                <Button Grid.Column="1"
                        Content="{x:Bind ViewModel.NextButtonText, Mode=OneWay}"
                        Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GoNextCommand}"
                        Visibility="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
