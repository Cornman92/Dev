<!-- Better11 System Enhancement Suite - UpdatesPage.xaml -->
<!-- Dense WinUtil-inspired Windows Update manager with update lists and settings -->
<Page
    x:Class="Better11.App.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE777;" FontSize="20" Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CheckForUpdatesCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        <TextBlock Text="Check for Updates"/>
                    </StackPanel>
                </Button>
                <Button Content="Install All"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.InstallAllUpdatesCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,8">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}">

                <!-- ─── Summary Cards Row ─── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource B11DenseCardStyle}" Margin="0,0,4,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Available"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.AvailableUpdateCount, Mode=OneWay}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource B11AccentBrush}"/>
                                <TextBlock Text="updates"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource B11DenseCardStyle}" Margin="2,0,2,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Total Size"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalSizeText, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource B11DenseCardStyle}" Margin="4,0,0,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Status"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource B11SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Up to date"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ─── Available Updates ─── -->
                <TextBlock Text="Available Updates" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <!-- Column Headers -->
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text=""  Width="24"/>
                            <TextBlock Grid.Column="1" Text="Name"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="KB"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="Size"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Type"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="Date"
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}" Margin="0,0,0,2"/>

                        <ListView ItemsSource="{x:Bind ViewModel.AvailableUpdates, Mode=OneWay}"
                                  SelectionMode="None"
                                  ItemContainerStyle="{StaticResource B11DenseListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="{StaticResource B11CompactRowHeight}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="&#xE896;" FontSize="12"
                                                  Foreground="{StaticResource B11AccentBrush}"
                                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                   FontSize="{StaticResource B11FontSizeBody}"
                                                   Foreground="{StaticResource B11TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding KbNumber}"
                                                   FontSize="{StaticResource B11FontSizeCaption}"
                                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                                   FontFamily="{StaticResource B11FontFamilyMono}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding SizeText}"
                                                   FontSize="{StaticResource B11FontSizeCaption}"
                                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Category}"
                                                   FontSize="{StaticResource B11FontSizeCaption}"
                                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding DateText}"
                                                   FontSize="{StaticResource B11FontSizeCaption}"
                                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                            <ListView.Footer>
                                <TextBlock Text="No updates available. System is up to date."
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"
                                           Margin="0,6,0,6"
                                           HorizontalAlignment="Center"/>
                            </ListView.Footer>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- ─── Installed Updates History ─── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Installed Updates History"
                               Style="{StaticResource B11SectionHeaderStyle}"/>
                    <Button Grid.Column="1" Content="Load History"
                            Style="{StaticResource B11CompactButtonStyle}"
                            Command="{x:Bind ViewModel.LoadHistoryCommand}"
                            VerticalAlignment="Center"/>
                </Grid>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <ListView ItemsSource="{x:Bind ViewModel.UpdateHistory, Mode=OneWay}"
                              SelectionMode="None"
                              ItemContainerStyle="{StaticResource B11DenseListViewItemStyle}"
                              MaxHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="{StaticResource B11CompactRowHeight}" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>

                                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="12"
                                              Foreground="{StaticResource B11SuccessBrush}"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding KbNumber}"
                                               FontSize="{StaticResource B11FontSizeCaption}"
                                               Foreground="{StaticResource B11TextSecondaryBrush}"
                                               FontFamily="{StaticResource B11FontFamilyMono}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding InstalledDate}"
                                               FontSize="{StaticResource B11FontSizeCaption}"
                                               Foreground="{StaticResource B11TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.Footer>
                            <TextBlock Text="Click 'Load History' to view installed updates."
                                       FontSize="{StaticResource B11FontSizeCaption}"
                                       Foreground="{StaticResource B11TextTertiaryBrush}"
                                       Margin="0,6,0,6"
                                       HorizontalAlignment="Center"/>
                        </ListView.Footer>
                    </ListView>
                </Border>

                <!-- ─── Update Settings ─── -->
                <TextBlock Text="Update Settings" Style="{StaticResource B11SectionHeaderStyle}"/>

                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <!-- Auto-download -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Auto-download updates"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Automatically download updates when available"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="True"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Auto-install -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Auto-install updates"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Install updates automatically during inactive hours"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="False"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Defer feature updates -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Defer feature updates"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Delay feature updates for stability testing"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="False"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource B11BorderSubtleBrush}"/>

                        <!-- Pause updates -->
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Pause all updates"
                                           FontSize="{StaticResource B11FontSizeBody}"
                                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                <TextBlock Text="Temporarily pause updates for 7 days"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="False"
                                          OnContent="" OffContent=""
                                          MinWidth="0" MinHeight="0"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
