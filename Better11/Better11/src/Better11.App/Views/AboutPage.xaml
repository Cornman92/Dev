<!-- Better11 System Enhancement Suite - AboutPage.xaml -->
<Page
    x:Class="Better11.App.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{StaticResource B11AccentBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                       FontSize="{StaticResource B11FontSizeTitle}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource B11TextPrimaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="{StaticResource B11SectionSpacing}" MaxWidth="600">

                <!-- App Identity -->
                <Border Style="{StaticResource B11DenseCardStyle}" Padding="16,12,16,12">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE770;" FontSize="36"
                                  Foreground="{StaticResource B11AccentBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Better11" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource B11TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="System Enhancement Suite"
                                   FontSize="{StaticResource B11FontSizeBody}"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersionDisplay, Mode=OneWay}"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Build Info -->
                <TextBlock Text="Build Information" Style="{StaticResource B11SectionHeaderStyle}"/>
                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="4">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Framework" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text=".NET 8.0 / WinUI 3" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        </Grid>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Architecture" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="MVVM + PowerShell Backend" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        </Grid>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PS Modules" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="102 complete" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        </Grid>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Test Methods" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="218+ (xUnit + Pester)" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Components -->
                <TextBlock Text="Components" Style="{StaticResource B11SectionHeaderStyle}"/>
                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource B11SuccessBrush}"/>
                            <TextBlock Text="Better.Wim" FontWeight="SemiBold" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="WIM Image Editor" FontSize="{StaticResource B11FontSizeCaption}" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource B11SuccessBrush}"/>
                            <TextBlock Text="Better.XML" FontWeight="SemiBold" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="Unattend.xml Generator" FontSize="{StaticResource B11FontSizeCaption}" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource B11SuccessBrush}"/>
                            <TextBlock Text="BetterPE" FontWeight="SemiBold" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="Custom WinPE/WinRE Builder" FontSize="{StaticResource B11FontSizeCaption}" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource B11SuccessBrush}"/>
                            <TextBlock Text="BetterBoot" FontWeight="SemiBold" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextPrimaryBrush}"/>
                            <TextBlock Text="12-Stage Deployment Pipeline" FontSize="{StaticResource B11FontSizeCaption}" Foreground="{StaticResource B11TextTertiaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Credits -->
                <TextBlock Text="Credits" Style="{StaticResource B11SectionHeaderStyle}"/>
                <Border Style="{StaticResource B11DenseCardStyle}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Inspired by Chris Titus Tech's WinUtil" FontSize="{StaticResource B11FontSizeBody}" Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Text="Built with WinUI 3, CommunityToolkit.Mvvm, Serilog" FontSize="{StaticResource B11FontSizeCaption}" Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <TextBlock Text="Actions" Style="{StaticResource B11SectionHeaderStyle}"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Open log folder" Command="{x:Bind ViewModel.OpenLogFolderCommand}" Style="{StaticResource B11AccentButtonStyle}"/>
                    <Button Content="Check for updates" Command="{x:Bind ViewModel.CheckForUpdatesCommand}" Style="{StaticResource B11AccentButtonStyle}"/>
                    <Button Content="Copy system info" Command="{x:Bind ViewModel.CopySystemInfoCommand}" Style="{StaticResource B11AccentButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
