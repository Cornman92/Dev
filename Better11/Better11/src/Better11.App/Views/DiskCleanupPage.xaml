<!-- Better11 System Enhancement Suite - DiskCleanupPage.xaml -->
<!-- Dense WinUtil-inspired disk cleanup with scan, category checkboxes, and progress -->
<Page
    x:Class="Better11.App.Views.DiskCleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource B11PrimaryBackgroundBrush}"
    NavigationCacheMode="Enabled">

    <Grid Padding="{StaticResource B11PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PAGE HEADER                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xEA99;" FontSize="20"
                          Foreground="{StaticResource B11AccentBrush}"/>
                <TextBlock Text="{x:Bind ViewModel.PageTitle}"
                           FontSize="{StaticResource B11FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource B11TextPrimaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Style="{StaticResource B11AccentButtonStyle}"
                        Command="{x:Bind ViewModel.ScanCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE9D9;" FontSize="12"/>
                        <TextBlock Text="Scan"/>
                    </StackPanel>
                </Button>
                <Button Content="Refresh"
                        Style="{StaticResource B11CompactButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="0,0,0,6">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Height="2"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error" Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsClosable="True"/>
            <InfoBar IsOpen="{x:Bind ViewModel.HasSuccess, Mode=OneWay}"
                     Severity="Success" Title="Success"
                     Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                     IsClosable="True"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- SCAN PROGRESS / SUMMARY                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource B11DenseCardStyle}"
                Margin="0,0,0,8">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Disk Space Overview -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Total Space"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalSpace, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource B11TextPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Used Space"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.UsedSpace, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Free Space"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.FreeSpace, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource B11SuccessBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Reclaimable"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextTertiaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalReclaimable, Mode=OneWay}"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource B11AccentBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Disk Usage Bar -->
                <ProgressBar Grid.Row="1"
                             Value="{x:Bind ViewModel.UsedPercentage, Mode=OneWay}"
                             Maximum="100" Height="6"
                             Background="{StaticResource B11SurfaceBackgroundBrush}"
                             Foreground="{StaticResource B11AccentBrush}"/>

                <!-- Scan Progress -->
                <StackPanel Grid.Row="2"
                            Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                            Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ProgressRing IsActive="True" Width="14" Height="14"/>
                        <TextBlock Text="{x:Bind ViewModel.ScanStatusText, Mode=OneWay}"
                                   FontSize="{StaticResource B11FontSizeCaption}"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    </StackPanel>
                    <ProgressBar Value="{x:Bind ViewModel.ScanProgress, Mode=OneWay}"
                                 Maximum="100" Height="4"
                                 Background="{StaticResource B11SurfaceBackgroundBrush}"
                                 Foreground="{StaticResource B11AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CLEANUP CATEGORIES LIST                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                  SelectionMode="None"
                  Background="Transparent">
            <ListView.Header>
                <Border Style="{StaticResource B11DenseCardStyle}"
                        Margin="0,0,0,2" Padding="8,4,8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  IsChecked="{x:Bind ViewModel.IsAllSelected, Mode=TwoWay}"
                                  MinWidth="0" MinHeight="0" Padding="0"
                                  ToolTipService.ToolTip="Select All"/>
                        <TextBlock Grid.Column="1" Text="Category"
                                   FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="Items"
                                   FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="Size"
                                   FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                        <TextBlock Grid.Column="4" Text="Risk"
                                   FontSize="{StaticResource B11FontSizeCaption}" FontWeight="SemiBold"
                                   Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </ListView.Header>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource B11DenseListViewItemStyle}">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource B11BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,3,0,3">
                        <Grid MinHeight="{StaticResource B11RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      MinWidth="0" MinHeight="0" Padding="0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="{Binding Icon}" FontSize="14"
                                              Foreground="{StaticResource B11AccentBrush}"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="{StaticResource B11FontSizeBody}"
                                               Foreground="{StaticResource B11TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{StaticResource B11TextTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="{Binding ItemCount}"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="3" Text="{Binding Size}"
                                       FontSize="{StaticResource B11FontSizeBody}"
                                       Foreground="{StaticResource B11TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource B11FontFamilyMono}"
                                       VerticalAlignment="Center"/>

                            <!-- Risk level badge -->
                            <Border Grid.Column="4" VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Background="{Binding RiskBackground}"
                                    CornerRadius="2" Padding="6,1,6,1">
                                <TextBlock Text="{Binding RiskLevel}"
                                           FontSize="{StaticResource B11FontSizeCaption}"
                                           Foreground="{Binding RiskForeground}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM ACTION BAR                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Style="{StaticResource B11DenseCardStyle}"
                Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Total Reclaimable from Selected -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SelectedCategoryCount, Mode=OneWay}"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11AccentBrush}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="categories selected"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="|"
                               Foreground="{StaticResource B11TextTertiaryBrush}"/>
                    <TextBlock Text="Space to reclaim:"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11TextSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.SelectedReclaimable, Mode=OneWay}"
                               FontSize="{StaticResource B11FontSizeBody}"
                               Foreground="{StaticResource B11AccentBrush}"
                               FontWeight="Bold"
                               FontFamily="{StaticResource B11FontFamilyMono}"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Style="{StaticResource B11AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CleanCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xEA99;" FontSize="12"/>
                            <TextBlock Text="Clean Selected"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource B11CompactButtonStyle}"
                            Command="{x:Bind ViewModel.SelectRecommendedCommand}"
                            Content="Select Recommended"/>
                    <Button Style="{StaticResource B11CompactButtonStyle}"
                            Command="{x:Bind ViewModel.ExportReportCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xEDE1;" FontSize="12"/>
                            <TextBlock Text="Export Report"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
