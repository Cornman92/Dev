# ===================
# Line Ending Rules
# ===================
# Default: auto-detect text files, normalize to CRLF on checkout (Windows workspace)
* text=auto eol=crlf

# ===================
# PowerShell
# ===================
*.ps1        text eol=crlf
*.psm1       text eol=crlf
*.psd1       text eol=crlf
*.ps1xml     text eol=crlf

# ===================
# Windows Scripts
# ===================
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.reg        text eol=crlf

# ===================
# Unix Scripts (keep LF)
# ===================
*.sh         text eol=lf
*.bash       text eol=lf

# ===================
# Web and Config
# ===================
*.json       text eol=crlf
*.xml        text eol=crlf
*.yaml       text eol=crlf
*.yml        text eol=crlf
*.toml       text eol=crlf
*.ini        text eol=crlf
*.cfg        text eol=crlf
*.conf       text eol=crlf

# ===================
# Source Code
# ===================
*.py         text eol=crlf diff=python
*.js         text eol=crlf
*.ts         text eol=crlf
*.cs         text eol=crlf diff=csharp
*.cpp        text eol=crlf diff=cpp
*.c          text eol=crlf diff=cpp
*.h          text eol=crlf diff=cpp

# ===================
# Documentation
# ===================
*.md         text eol=crlf diff=markdown
*.txt        text eol=crlf
*.rst        text eol=crlf

# ===================
# Binary Files (no text conversion)
# ===================
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.bmp        binary
*.tiff       binary
*.webp       binary
*.svg        text eol=crlf
*.pdf        binary
*.zip        binary
*.7z         binary
*.tar        binary
*.gz         binary
*.rar        binary
*.exe        binary
*.dll        binary
*.pdb        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
