  "PostInstallAutomation": [
    {
      "name": "Enable BitLocker",
      "command": "Enable-BitLocker -MountPoint 'C:' -EncryptionMethod XtsAes256 -UsedSpaceOnly -RecoveryPasswordProtector"
    },
    {
      "name": "Configure Firewall Rules",
      "command": "netsh advfirewall set allprofiles state on && netsh advfirewall firewall add rule name='Block Inbound SMB' dir=in action=block protocol=TCP localport=445"
    },
    {
      "name": "Enable Defender Exploit Guard",
      "command": "Set-MpPreference -EnableControlledFolderAccess Enabled -EnableNetworkProtection Enabled"
    },
    {
      "name": "Apply Ultimate Performance Plan",
      "command": "powercfg /setactive SCHEME_MIN"
    },

    {
      "name": "Schedule Weekly SSD Optimization",
      "command": "schtasks /create /tn \"SSDOptimize\" /tr \"defrag C: /O\" /sc weekly /d SUN /ru SYSTEM"
    },
    {
      "name": "Schedule Monthly Windows Update Cleanup",
      "command": "schtasks /create /tn \"WU-Cleanup\" /tr \"Dism.exe /Online /Cleanup-Image /StartComponentCleanup\" /sc monthly /d 1 /ru SYSTEM"
    },
    {
      "name": "Schedule Weekly Defender Scan",
      "command": "schtasks /create /tn \"DefenderQuickScan\" /tr \"MpCmdRun.exe -Scan -ScanType 1\" /sc weekly /d SAT /ru SYSTEM"
    },
    {
      "name": "Schedule Weekly Disk Health Check",
      "command": "schtasks /create /tn \"DiskHealthCheck\" /tr \"chkdsk /scan\" /sc weekly /d SUN /ru SYSTEM"
    },
    {
      "name": "Schedule Event Log Cleanup",
      "command": "schtasks /create /tn \"EventLogCleanup\" /tr \"wevtutil cl Application && wevtutil cl System\" /sc monthly /d 1 /ru SYSTEM"
    },

    {
      "name": "Self-Healing Tweaks",
      "command": "schtasks /create /tn \"ReapplyTweaks\" /tr \"powershell.exe -ExecutionPolicy Bypass -File C:\\\\Winutil\\\\ApplyTweaks.ps1\" /sc weekly /d MON /ru SYSTEM"
    },

    {
      "name": "Profile Backup to OneDrive",
      "command": "Copy-Item C:\\\\Winutil\\\\Connor-ConnorOS-Winutil.json $env:OneDrive\\\\Backups\\\\ConnorOS.json -Force"
    },
    {
      "name": "Export Installed App List",
      "command": "winget export -o $env:OneDrive\\\\Backups\\\\InstalledApps.json"
    },

    {
      "name": "Gaming - Disable Fullscreen Optimizations",
      "command": "reg add \"HKCU\\\\System\\\\GameConfigStore\" /v GameDVR_FSEBehaviorMode /t REG_DWORD /d 2 /f"
    },
    {
      "name": "Gaming - Disable DVR Background Recording",
      "command": "reg add \"HKCU\\\\System\\\\GameConfigStore\" /v GameDVR_Enabled /t REG_DWORD /d 0 /f"
    },
    {
      "name": "Gaming - Optimize Network Stack",
      "command": "netsh int tcp set global autotuninglevel=normal && netsh int tcp set global rss=enabled"
    },

    {
      "name": "Developer - Docker Cleanup",
      "command": "schtasks /create /tn \"DockerPrune\" /tr \"docker system prune -af\" /sc monthly /d 1 /ru SYSTEM"
    },
    {
      "name": "Developer - VSCode Extension Export",
      "command": "code --list-extensions > $env:OneDrive\\\\Backups\\\\VSCodeExtensions.txt"
    },

    {
      "name": "System - Timezone Sync",
      "command": "tzutil /s \"Eastern Standard Time\" && w32tm /resync"
    },
    {
      "name": "System - Disable Autoplay",
      "command": "reg add \"HKCU\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Policies\\\\Explorer\" /v NoDriveTypeAutoRun /t REG_DWORD /d 255 /f"
    },
    {
      "name": "System - Disable SMBv1",
      "command": "Disable-WindowsOptionalFeature -Online -FeatureName SMB1Protocol -NoRestart"
    },

    {
      "name": "Network - Flush DNS Weekly",
      "command": "schtasks /create /tn \"DNSFlush\" /tr \"ipconfig /flushdns\" /sc weekly /d MON /ru SYSTEM"
    },
    {
      "name": "Network - Winsock Reset Monthly",
      "command": "schtasks /create /tn \"WinsockReset\" /tr \"netsh winsock reset\" /sc monthly /d 1 /ru SYSTEM"
    },

    {
      "name": "Monitoring - Weekly Health Dashboard",
      "command": "schtasks /create /tn \"HealthDashboard\" /tr \"powershell.exe -Command \\\"Get-ComputerInfo | ConvertTo-Html | Out-File $env:OneDrive\\\\Reports\\\\HealthDashboard.html\\\"\" /sc weekly /d SUN /ru SYSTEM"
    },
    {
      "name": "Monitoring - Backup Verification",
      "command": "schtasks /create /tn \"BackupVerify\" /tr \"powershell.exe -Command \\\"Get-FileHash $env:OneDrive\\\\Backups\\\\ConnorOS.json | Out-File $env:OneDrive\\\\Reports\\\\BackupHash.txt\\\"\" /sc weekly /d SUN /ru SYSTEM"
    }
  ]
}
