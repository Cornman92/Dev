{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Better11 Project Schema",
  "type": "object",
  "required": [
    "name",
    "iso",
    "appsCatalog",
    "installerMetadata",
    "profile",
    "options"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "iso": {
      "type": "object",
      "required": [
        "label",
        "sourcePath",
        "outputIso"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "outputIso": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "appsCatalog": {
      "type": "string"
    },
    "installerMetadata": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "options": {
      "type": "object",
      "required": [
        "buildISO",
        "whatIf",
        "offlineOnly",
        "maxConcurrency"
      ],
      "properties": {
        "buildISO": {
          "type": "boolean"
        },
        "whatIf": {
          "type": "boolean"
        },
        "offlineOnly": {
          "type": "boolean"
        },
        "maxConcurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        }
      }
    }
  }
}
