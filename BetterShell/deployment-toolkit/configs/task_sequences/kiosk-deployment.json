[
  {
    "id": "kiosk-deployment",
    "name": "Kiosk mode deployment",
    "description": "Deploys Windows configured for kiosk mode with assigned access and restricted user interface.",
    "steps": [
      {
        "id": "detect-hardware",
        "name": "Detect hardware",
        "type": "DetectHardware",
        "inputs": {}
      },
      {
        "id": "partition-disk",
        "name": "Partition target disk",
        "type": "PartitionDisk",
        "inputs": {
          "_comment": "diskNumber can be overridden via Variables['DiskNumber']",
          "diskNumber": 0,
          "partitionStyle": "GPT",
          "force": true,
          "layout": [
            {
              "sizeGB": 0.1,
              "fileSystem": "FAT32",
              "label": "SYSTEM",
              "driveLetter": "S",
              "isBoot": true,
              "isSystem": true,
              "gptType": "{C12A7328-F81F-11D2-BA4B-00A0C93EC93B}"
            },
            {
              "sizeGB": 0.016,
              "fileSystem": "",
              "label": "",
              "driveLetter": "",
              "isBoot": false,
              "isSystem": false,
              "gptType": "{E3C9E316-0B5C-4DB8-817D-F92DF00215AE}"
            },
            {
              "sizeGB": 0,
              "fileSystem": "NTFS",
              "label": "Windows",
              "driveLetter": "C",
              "isBoot": false,
              "isSystem": false,
              "gptType": "{EBD0A0A2-B9E5-4433-87C0-68B6B72699C7}"
            }
          ]
        }
      },
      {
        "id": "apply-image",
        "name": "Apply Windows image",
        "type": "ApplyImage",
        "inputs": {
          "wimPath": "%WIM_PATH%",
          "_wimPathFallback": "X:\\sources\\install.wim",
          "index": 1,
          "targetDriveLetter": "C"
        }
      },
      {
        "id": "inject-drivers",
        "name": "Inject drivers offline",
        "type": "InjectDrivers",
        "inputs": {
          "mode": "offline-os",
          "maxPacks": 3
        }
      },
      {
        "id": "configure-boot",
        "name": "Configure bootloader",
        "type": "ConfigureBoot",
        "inputs": {
          "systemPartitionDriveLetter": "S"
        }
      },
      {
        "id": "apply-kiosk-optimization",
        "name": "Apply kiosk optimization profile",
        "type": "ApplyOptimizationProfile",
        "inputs": {
          "profileId": "minimal"
        }
      },
      {
        "id": "apply-kiosk-debloat",
        "name": "Apply aggressive debloat for kiosk",
        "type": "ApplyDebloatProfile",
        "inputs": {
          "profileId": "aggressive"
        }
      },
      {
        "id": "configure-kiosk-mode",
        "name": "Configure kiosk mode (placeholder)",
        "type": "RunProcess",
        "inputs": {
          "_comment": "Kiosk mode configuration requires assigned access setup",
          "executable": "powershell.exe",
          "arguments": "-Command Write-Host 'Kiosk mode configuration - implement with assigned access PowerShell cmdlets'"
        }
      },
      {
        "id": "reboot",
        "name": "Reboot into kiosk mode",
        "type": "Reboot",
        "inputs": {}
      }
    ]
  }
]

