[
  {
    "id": "baremetal-basic",
    "name": "Bare-metal GPT deployment (single OS partition)",
    "description": "Wipes the selected disk, creates EFI/MSR/OS partitions, applies a WIM, configures boot, and reboots.",
    "steps": [
      {
        "id": "partition-disk",
        "name": "Partition target disk",
        "type": "PartitionDisk",
        "inputs": {
          "_comment": "diskNumber can be overridden via Variables['DiskNumber'] in task sequence execution",
          "diskNumber": 0,
          "partitionStyle": "GPT",
          "force": true,
          "layout": [
            {
              "sizeGB": 0.1,
              "fileSystem": "FAT32",
              "label": "SYSTEM",
              "driveLetter": "S",
              "isBoot": true,
              "isSystem": true,
              "gptType": "{C12A7328-F81F-11D2-BA4B-00A0C93EC93B}"
            },
            {
              "sizeGB": 0.016,
              "fileSystem": "",
              "label": "",
              "driveLetter": "",
              "isBoot": false,
              "isSystem": false,
              "gptType": "{E3C9E316-0B5C-4DB8-817D-F92DF00215AE}"
            },
            {
              "sizeGB": 0,
              "fileSystem": "NTFS",
              "label": "Windows",
              "driveLetter": "C",
              "isBoot": false,
              "isSystem": false,
              "gptType": "{EBD0A0A2-B9E5-4433-87C0-68B6B72699C7}"
            }
          ]
        }
      },
      {
        "id": "apply-image",
        "name": "Apply Windows image",
        "type": "ApplyImage",
        "inputs": {
          "_comment": "WIM path supports environment variables: %WIM_PATH%, %INSTALL_WIM%, or %DEPLOY_SHARE%\\sources\\install.wim",
          "_comment2": "Default: X:\\sources\\install.wim (typical WinPE location)",
          "wimPath": "%WIM_PATH%",
          "_wimPathFallback": "X:\\sources\\install.wim",
          "index": 1,
          "targetDriveLetter": "C"
        }
      },
      {
        "id": "configure-boot",
        "name": "Configure bootloader",
        "type": "ConfigureBoot",
        "inputs": {
          "systemPartitionDriveLetter": "S"
        }
      },
      {
        "id": "reboot",
        "name": "Reboot into new OS",
        "type": "Reboot",
        "inputs": {}
      }
    ]
  }
]

