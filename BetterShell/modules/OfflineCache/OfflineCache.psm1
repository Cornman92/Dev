function Invoke-AuroraPrefetch { [CmdletBinding(SupportsShouldProcess=$true)] param([Parameter(Mandatory)][string]$InstallerMetadataPath,[string]$DownloadMapPath=(Join-Path $PSScriptRoot 'download_map.json'),[switch]$WhatIf) $meta=Get-Content -LiteralPath $InstallerMetadataPath -Raw | ConvertFrom-Json; $cache=(Join-Path (Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path 'Cache'); if(-not (Test-Path $cache)){ New-Item -ItemType Directory -Force -Path $cache | Out-Null } $map=@(); if(Test-Path -LiteralPath $DownloadMapPath){ $map=Get-Content -LiteralPath $DownloadMapPath -Raw | ConvertFrom-Json } $out=@(); foreach($m in $meta){ $need=$true; try{ if($m.Path -and (Test-Path -LiteralPath $m.Path)){ $h=(Get-FileHash -Algorithm SHA256 -LiteralPath $m.Path).Hash; if(-not $m.Sha256 -or $h -eq $m.Sha256){ $need=$false } } }catch{} if($need){ $rec=$map | Where-Object { $_.Name -eq $m.Name }; if(-not $rec){ $out += [pscustomobject]@{ Name=$m.Name; Status='MissingURL' }; continue } $url=$rec.Url; $file=Join-Path $cache (('{0}_{1}' -f $m.Name,(Split-Path -Leaf $url))); if($PSCmdlet.ShouldProcess($url,'Download')){ try{ Invoke-WebRequest -Uri $url -OutFile $file -UseBasicParsing; if($m.Sha256){ $h=(Get-FileHash -Algorithm SHA256 -LiteralPath $file).Hash; if($h -ne $m.Sha256){ $out += [pscustomobject]@{ Name=$m.Name; Status='HashMismatch'; Path=$file }; continue } } $m.Path=$file; $out += [pscustomobject]@{ Name=$m.Name; Status='Downloaded'; Path=$file } }catch{ $out += [pscustomobject]@{ Name=$m.Name; Status='Error'; Error=$_.Exception.Message } } } else { $out += [pscustomobject]@{ Name=$m.Name; Status='OK'; Path=$m.Path } } } $meta | ConvertTo-Json -Depth 6 | Set-Content -LiteralPath $InstallerMetadataPath -Encoding UTF8; return $out } Export-ModuleMember -Function Invoke-AuroraPrefetch
