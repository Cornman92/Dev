function Test-AuroraCertificates{ $cs=Get-ChildItem Cert:\CurrentUser\My | Where-Object { $_.EnhancedKeyUsageList.FriendlyName -contains 'Code Signing' }; $exp=@($cs | Where-Object { $_.NotAfter -lt (Get-Date).AddDays(30) }); [pscustomobject]@{ CodeSigningCerts=$cs.Count; ExpiringSoon=$exp.Count } } function Test-AuroraHashes{ param([string]$Root=(Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path); $issues=@(); Get-ChildItem $Root -Recurse -Include *.exe,*.msi -File -ErrorAction SilentlyContinue | ForEach-Object { try{ $h=(Get-FileHash -Algorithm SHA256 -LiteralPath $_.FullName).Hash }catch{ $h=$null } if(-not $h){ $issues+=$_.FullName } }; [pscustomobject]@{ MissingHashes=$issues } } Export-ModuleMember -Function Test-AuroraCertificates,Test-AuroraHashes
