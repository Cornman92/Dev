function Get-AuroraTelemetryConfig{param([string]$Path=(Join-Path $PSScriptRoot '..\..\Config\telemetry.json')); if(Test-Path $Path){ Get-Content $Path -Raw | ConvertFrom-Json } else { @{ enabled=$false; endpoint=''; token='' } } } function Write-AuroraTelemetryLocal{param([hashtable]$Data,[string]$OutDir=(Join-Path $PSScriptRoot '..\..\Output\telemetry')); if(-not (Test-Path $OutDir)){ New-Item -ItemType Directory -Force -Path $OutDir | Out-Null } $ts=Get-Date -Format 'yyyyMMdd_HHmmss'; $file=Join-Path $OutDir ("telemetry_{0}.json" -f $ts); ($Data | ConvertTo-Json -Depth 6) | Set-Content $file; $file } function Send-AuroraTelemetryRemote{param([hashtable]$Data,[hashtable]$Cfg); if(-not $Cfg -or -not $Cfg.enabled -or -not $Cfg.endpoint){ return $false } try{ $hdr=@{}; if($Cfg.token){ $hdr['Authorization']="Bearer $($Cfg.token)" }; Invoke-RestMethod -Uri $Cfg.endpoint -Method Post -Headers $hdr -Body ($Data | ConvertTo-Json -Depth 6) -ContentType 'application/json'; $true }catch{ $false } } Export-ModuleMember -Function Get-AuroraTelemetryConfig,Write-AuroraTelemetryLocal,Send-AuroraTelemetryRemote
