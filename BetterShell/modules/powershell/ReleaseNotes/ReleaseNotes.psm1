function New-AuroraReleaseNotes { param([string]$LogsDir=(Join-Path $PSScriptRoot '..\..\Output'),[string]$OutDir=(Join-Path $PSScriptRoot '..\..\Output\releases')) if(-not (Test-Path $OutDir)){ New-Item -ItemType Directory -Force -Path $OutDir | Out-Null } $ts=Get-Date -Format 'yyyyMMdd_HHmmss'; $md=Join-Path $OutDir ('release_{0}.md' -f $ts); $logs=Get-ChildItem -LiteralPath $LogsDir -Filter *.log -ErrorAction SilentlyContinue | Sort-Object LastWriteTime -Descending | Select-Object -First 5; $reports=Get-ChildItem -LiteralPath $LogsDir -Filter report_*.json -ErrorAction SilentlyContinue | Sort-Object LastWriteTime -Descending | Select-Object -First 3; $content=@('# Aurora Release Notes {0}' -f $ts,'','## Recent logs',''); foreach($l in $logs){ $content += ('* {0}' -f $l.Name) } $content += '','## Recent reports',''; foreach($r in $reports){ $content += ('* {0}' -f $r.Name) } $content += '','_Auto-generated by Aurora_'; ($content -join "`r`n") | Set-Content -LiteralPath $md -Encoding UTF8; return $md } Export-ModuleMember -Function New-AuroraReleaseNotes
