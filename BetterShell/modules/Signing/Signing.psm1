function Invoke-AuroraSigning { param([string]$Root=(Resolve-Path (Join-Path $PSScriptRoot '..\..')).Path,[string]$Thumbprint,[string]$TimestampUrl='http://timestamp.digicert.com',[switch]$WhatIf) $cert=$null; if($Thumbprint){$cert=Get-ChildItem Cert:\CurrentUser\My | Where-Object Thumbprint -eq $Thumbprint}else{$cert=Get-ChildItem Cert:\CurrentUser\My | Where-Object { $_.EnhancedKeyUsageList.FriendlyName -contains 'Code Signing'}|Select-Object -First 1}; if(-not $cert){[pscustomobject]@{Performed=$false;Reason='NoCodeSigningCert';Files=0}; return}; $targets=Get-ChildItem -LiteralPath $Root -Recurse -Include *.ps1,*.psm1,*.psd1 -File; $count=0; foreach($t in $targets){ try{ if($PSCmdlet.ShouldProcess($t.FullName,'Sign')){ Set-AuthenticodeSignature -FilePath $t.FullName -Certificate $cert -TimestampServer $TimestampUrl | Out-Null; $count++ } }catch{} }; [pscustomobject]@{Performed=$true;Signed=$count;Thumbprint=$cert.Thumbprint} } Export-ModuleMember -Function Invoke-AuroraSigning
