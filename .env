# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
GAYMERPC_OS=Windows 11 Pro x64
GAYMERPC_OS_VERSION=24H2
GAYMERPC_OS_BUILD=22631
GAYMERPC_OS_ARCH=x64

GAYMERPC_WORKSPACE_ROOT=D:\Dev
GAYMERPC_PROJECT_ROOT=D:\Dev\GaymerPC
