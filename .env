# =============================================================================
# PERFORMANCE OPTIMIZATION
# =============================================================================
GAYMERPC_PERFORMANCE_MODE=gaming
GAYMERPC_POWER_PLAN=ultimate_performance
GAYMERPC_CPU_OVERCLOCK=false
GAYMERPC_GPU_OVERCLOCK=false
GAYMERPC_RAM_XMP=true
