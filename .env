GAYMERPC_POWER_LIMIT=100

# Gaming Performance Targets
GAYMERPC_TARGET_FPS=144
GAYMERPC_TARGET_RESOLUTION=2560x1440
GAYMERPC_TARGET_REFRESH_RATE=144
GAYMERPC_DLSS_ENABLED=true
GAYMERPC_RAY_TRACING=balanced
GAYMERPC_ANTI_ALIASING=TAA

# =============================================================================
# AI CONFIGURATION
# =============================================================================
GAYMERPC_AI_ENABLED=true
GAYMERPC_AI_GAMING_COACH=true
GAYMERPC_AI_AUTOMATION=true
GAYMERPC_AI_PREDICTIVE=true
GAYMERPC_AI_LEARNING=true
GAYMERPC_AI_WAKE_WORD=C-MAN
GAYMERPC_AI_VOICE_ENABLED=true
GAYMERPC_AI_VISION_ENABLED=true

